# Токен бота от @BotFather
BOT_TOKEN=

# Адрес API давомата
API_BASE_URL=https://localhost:7052/api

# Учётка администратора — бот читает данные давомата под ней
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=

# Разрешить самоподписанный TLS-сертификат (ТОЛЬКО для локальной разработки)
API_INSECURE_TLS=true

# Авто-отчёт по расписанию (необязательно)
# Куда слать ежедневный отчёт (id чата/группы). Пусто = авто-отчёт выключен.
REPORT_CHAT_ID=
# Когда слать (cron). По умолчанию каждый день в 18:30.
REPORT_CRON=30 18 * * *
# Часовой пояс расписания.
REPORT_TZ=Asia/Tashkent
